{% if isLive %}
<fieldset>
    <legend class="h6">{{ 'Short Link' | t('dub') }}</legend>
    <div class="meta">
        {% if isLive %}
        <div class="field">
            <div class="heading">{{ 'Slug' | t('dub') }}</div>
            <div class="input">
                {% if hasApiKey %}
                    {% if shortLink %}<input type="hidden" name="dubShortLinkPresent" value="1">{% endif %}
                    <input type="text" class="text" name="dubCustomKey" value="{{ currentKey ?? '' }}" placeholder="{{ '' | t('dub') }}">
                {% else %}
                    <a href="{{ settingsUrl }}">{{ 'Add API Key' | t('dub') }}</a>
                {% endif %}
            </div>
        </div>
        {% endif %}
        {% if shortLink %}
            <div class="field">
                <div class="heading">{{ 'Link' | t('dub') }}</div>
                <div class="input flex flex-nowrap" style="align-items: center; justify-content: space-between; gap: 6px;">
                    <a href="{{ shortLink }}" target="_blank" rel="noopener" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;">{{ shortLink | replace('https://', '') }}</a>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button type="button"
                            data-url="{{ shortLink }}"
                            title="{{ 'Copy to clipboard' | t('dub') }}"
                            aria-label="{{ 'Copy to clipboard' | t('dub') }}"
                            style="background: none; border: none; padding: 0; cursor: pointer; --icon-color: var(--gray-500);"
                            onclick="var b=this;navigator.clipboard.writeText(b.dataset.url).then(function(){b.classList.add('dub-copied');setTimeout(function(){b.classList.remove('dub-copied')},1500)})">
                            <span class="cp-icon small dub-copy-clipboard">{{ iconSvg('clipboard') }}</span>
                            <span class="cp-icon small dub-copy-check">{{ iconSvg('check') }}</span>
                        </button>
                        {% if dubDashboardUrl %}
                            <a href="{{ dubDashboardUrl }}" target="_blank" rel="noopener"
                                title="{{ 'View in Dub' | t('dub') }}"
                                style="display: flex; color: var(--gray-500);">
                                <svg width="14" height="14" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M32 64c17.673 0 32-14.327 32-32 0-11.844-6.435-22.186-16-27.719V48h-8v-2.14A15.9 15.9 0 0 1 32 48c-8.837 0-16-7.163-16-16s7.163-16 16-16c2.914 0 5.647.78 8 2.14V1.008A32 32 0 0 0 32 0C14.327 0 0 14.327 0 32s14.327 32 32 32" fill="currentColor"/></svg>
                            </a>
                        {% endif %}
                    </div>
                    <style>
                        .dub-copy-check { display: none; }
                        .dub-copied .dub-copy-clipboard { display: none; }
                        .dub-copied .dub-copy-check { display: flex; }
                    </style>
                </div>
            </div>
        {% endif %}
    </div>
</fieldset>
{% endif %}
